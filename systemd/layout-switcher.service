[Unit]
Description=Layout Switcher daemon
After=graphical-session.target ydotoold.service
Wants=ydotoold.service
PartOf=graphical-session.target

[Service]
Type=simple
Environment=YDTOOL_SOCKET=/run/user/%U/.ydotool_socket
ExecStart=%h/.local/share/layout-switcher/venv/bin/layout-switcher --config %h/.config/layout-switcher/config.json
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
